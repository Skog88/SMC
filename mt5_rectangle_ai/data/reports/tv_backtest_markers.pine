var gbpusd_epx = array.from(1.35075, 1.35157, 1.35086, 1.35035, 1.3465, 1.35209, 1.35352, 1.35442, 1.35564, 1.35328, 1.35329, 1.35072, 1.35152, 1.35216, 1.35056, 1.34815, 1.34615, 1.3459, 1.3492, 1.3496, 1.35159, 1.35903, 1.3622, 1.35872, 1.35555, 1.35276, 1.35469, 1.35666)
var gbpusd_sl = array.from(1.35053, 1.35246, 1.35102, 1.35133, 1.34589, 1.35235, 1.35393, 1.35469, 1.35586, 1.35306, 1.35313, 1.35021, 1.35176, 1.35231, 1.35006, 1.34795, 1.34552, 1.34541, 1.35004, 1.35048, 1.35208, 1.35948, 1.36145, 1.35855, 1.35499, 1.35255, 1.35505, 1.35699)
